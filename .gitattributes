# デフォルト: 全テキストファイルを LF に正規化
* text=auto eol=lf

# Windows 固有ファイルは CRLF を維持
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# --- テキストファイル (フロントエンド) ---
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.css text eol=lf
*.html text eol=lf

# --- テキストファイル (バックエンド: FastAPI / Python) ---
*.py text eol=lf
*.pyi text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.sql text eol=lf

# --- テキストファイル (インフラ・スクリプト) ---
*.sh text eol=lf
Makefile text eol=lf
Dockerfile* text eol=lf
.dockerignore text eol=lf
justfile text eol=lf

# --- 設定・ドキュメント ---
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.graphql text eol=lf
*.gql text eol=lf
*.env* text eol=lf
*.txt text eol=lf

# --- SVG: テキスト扱いで差分を有効化 ---
*.svg text eol=lf

# --- バイナリファイル ---
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.avif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.pyc binary

# --- 生成ファイル（GitHub の差分・言語統計から除外） ---
pnpm-lock.yaml linguist-generated=true -diff
uv.lock linguist-generated=true -diff
next-env.d.ts linguist-generated=true